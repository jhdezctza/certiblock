generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  name      String
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Student {
  matricula String   @id
  name      String
  career    String
  createdAt DateTime @default(now()) @map("created_at")

  certificates Certificate[]

  @@map("students")
}

model Certificate {
  id           Int      @id @default(autoincrement())
  matricula    String
  // JWT es largo; en MySQL String por defecto suele terminar como VARCHAR(191) y se trunca.
  // Usamos un tamaño explícito para evitar truncamiento y que la búsqueda por hash funcione.
  hash         String   @unique @db.VarChar(2048)
  ipfsHash     String?  @map("ipfs_hash")
  blockchainTx String?  @map("blockchain_tx")
  createdAt    DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [matricula], references: [matricula])

  @@map("certificates")
}