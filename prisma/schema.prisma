generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  name      String
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Student {
  matricula String   @id
  name      String
  career    String
  createdAt DateTime @default(now()) @map("created_at")

  certificates Certificate[]

  @@map("students")
}

model Certificate {
  id           Int      @id @default(autoincrement())
  matricula    String
  // Legacy/compat: este campo puede estar truncado en instalaciones viejas.
  // Ya no se usa para búsqueda exacta.
  hash         String   @db.VarChar(191)
  // JWT completo (para validación/recuperación).
  hashFull     String?  @map("hash_full") @db.LongText
  // Digest fijo (sha256 hex) para búsquedas/index y blockchain.
  hashDigest   String?  @unique @map("hash_digest") @db.VarChar(64)
  ipfsHash     String?  @map("ipfs_hash")
  blockchainTx String?  @map("blockchain_tx")
  createdAt    DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [matricula], references: [matricula])

  @@map("certificates")
}